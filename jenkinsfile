pipeline {
    agent any
    stages {
        stage('Clone') {
            steps {
                // 克隆 Spring Boot 项目的 Git 仓库到工作空间
                git 'http://192.168.2.35:8989/root/lims.git'
            }
        }
        stage('Build') {
            steps {
                // 使用 Maven 打包项目
                sh 'mvn clean package'
            }
        }
        stage('Deploy') {
            steps {
                // 使用 SSH 插件连接到目标服务器
                withCredentials([usernamePassword(credentialsId: 'my-creds-id', usernameVariable: 'root', passwordVariable: 'hntri@3.14')]) {
                    sh "sshpass -p hntri@3.14 ssh root@192.168.2.202 'cd /home/lims/deployment; ./deploy.sh'"
                }
            }
        }
        stage('Test') {
            steps {
                // 运行集成测试套件
                sh 'mvn test'
            }
        }
        stage('Cleanup') {
            steps {
                // 清理构建产物
                sh 'mvn clean'
            }
        }
    }
}
