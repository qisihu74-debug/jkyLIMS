<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.lims.manage.erp.mapper.NewsDao">

    <insert id="addBatchLinkedData" parameterType="com.lims.manage.erp.vo.LinkedDataVo">
        insert into sys_linked_data
        (id,name,url,sys_news_id)
        values
        <foreach collection="items" item="item" open="" separator="," close="">
        (id,#{item.name},#{item.url},#{item.sysNewsId})
        </foreach>
    </insert>

    <select id="selectLinkedList" resultType="com.lims.manage.erp.vo.LinkedDataVo">
        SELECT id,name,url FROM sys_linked_data  WHERE sys_news_id = #{sysNewsId}
    </select>
</mapper>