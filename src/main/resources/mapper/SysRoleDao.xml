<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.lims.manage.erp.mapper.SysRoleDao">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.lims.manage.erp.entity.SysRoleEntity" id="sysRoleMap">
        <result property="roleId" column="role_id"/>
        <result property="roleName" column="role_name"/>
        <result property="remark" column="remark"/>
        <result property="createTime" column="create_time"/>
    </resultMap>


    <!-- 查询用户角色集合 -->
    <select id="selectSysRoleByUserId"  parameterType="long" resultType="com.lims.manage.erp.entity.SysRoleEntity" >
        SELECT sr.* FROM sys_role sr
        LEFT JOIN sys_user_role se ON sr.role_id=se.role_id
        WHERE se.user_id = #{userId}
    </select>

    <select id="selectSysRoleList" resultType="com.lims.manage.erp.entity.SysRoleEntity" parameterType="com.lims.manage.erp.entity.SysRoleEntity">
        SELECT
        role_id,
        role_name,
        role_remark,
        create_time,
        is_delete
        FROM
        sys_role
        <trim prefix="WHERE" prefixOverrides="AND |OR ">
        <if test="roleName!=null and roleName!=''">
            and role_name LIKE CONCAT('%',#{roleName},'%')
        </if>
        <if test="roleRemark!=null and roleRemark!=''">
            and role_remark LIKE CONCAT('%',#{roleRemark},'%')
        </if>
    </trim>

    </select>

    <select id="selectSysyRoleName" resultType="com.lims.manage.erp.vo.LabelValueVo">
        select
        t1.name AS label,
        t1.user_id AS VALUE
        FROM
        sys_user as t1
        LEFT JOIN sys_user_role as t2 ON t1.user_id = t2.user_id
        LEFT JOIN sys_role as t3 ON t3.role_id = t2.role_id
        WHERE t3.role_id = #{roleId}
    </select>

</mapper>