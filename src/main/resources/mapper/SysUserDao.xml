<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.lims.manage.erp.mapper.SysUserDao">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.lims.manage.erp.entity.SysUserEntity" id="sysUserMap">
        <result property="userId" column="user_id"/>
        <result property="username" column="username"/>
        <result property="password" column="password"/>
        <result property="salt" column="salt"/>
        <result property="email" column="email"/>
        <result property="mobile" column="mobile"/>
        <result property="img" column="img"/>
        <result property="intro" column="intro"/>
        <result property="deptId" column="dept_id"/>
        <result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
        <result property="createUser" column="create_user"/>
        <result property="modifyTime" column="modify_time"/>
        <result property="modifyUser" column="modify_user"/>
    </resultMap>

    <resultMap id="resultUserInfo" type="com.lims.manage.erp.vo.UserInfoVo">
        <result property="userId" column="user_id"/>
        <result property="username" column="username"/>
        <result property="createTime" column="create_time"/>
        <result property="state" column="state"/>
        <result property="note" column="note"/>
        <result property="name" column="name"/>
        <result property="mobile" column="mobile"/>
        <result property="dingUserId" column="ding_user_id"/>
<!--        <result property="position" column="position"/>-->
        <result property="email" column="email"/>
        <result property="departmentId" column="department"/>
        <collection property="roles" ofType="com.lims.manage.erp.vo.LabelValueVo">
            <result property="label" column="role_name"/>
            <result property="value" column="role_id"/>
        </collection>
    </resultMap>

    <update id="updateUserState">
        UPDATE sys_user SET state=#{state},time=#{time} WHERE user_id = #{userId}
    </update>

    <update id="resetPassword">
        UPDATE sys_user
        SET PASSWORD = #{password}, salt = #{salt},time=#{time}
        WHERE
            user_id = #{userId}
    </update>

    <select id="getUserInfos" resultMap="resultUserInfo" parameterType="com.lims.manage.erp.vo.UserInfoParamVo">
        SELECT
        DISTINCT t1.user_id,
        t1.username,
        t1.state,
        t1.create_time,
        t1.note,
        t1.mobile,
        t1.email,
        t1.department,
        t3.role_id,
        t4.role_name,
        t1.NAME,
        t1.ding_user_id
        FROM
        sys_user t1
        left join sys_user_role t3 on t1.user_id = t3.user_id
        left join sys_role t4 on t3.role_id = t4.role_id
        LEFT JOIN sys_ding_user t5 ON t5.userid = t1.ding_user_id
        where 1=1
        <if test="username != null and username != ''">
            and t1.username like CONCAT('%',#{username},'%')
        </if>
        <if test="mobile != null and mobile != ''">
            and t1.mobile like CONCAT('%',#{mobile},'%')
        </if>
        <if test="deptId != null and deptId != ''">
            and t1.department like CONCAT('%',#{deptId},'%')
        </if>
        <if test="state != null and state != ''">
            and t1.state = #{state}
        </if>
        order by t1.time desc
    </select>

    <update id="updateUserInfo" parameterType="com.lims.manage.erp.vo.UserInfoVo">
        UPDATE sys_user
        SET name = #{name},
            mobile = #{mobile},
            email = #{email},
            department = #{departmentId},
            note = #{note},
            username = #{username},
            ding_user_id = #{dingUserId},
            time = #{time}
        WHERE
            user_id = #{userId}
    </update>

    <select id="selectUserinfoList" resultType="com.lims.manage.erp.entity.SysUserTreeEntity" parameterType="com.lims.manage.erp.entity.SysUserTreeEntity">
        SELECT
            t2.user_id,
            t2.username as loginName,
            t1.NAME as username,
            t1.mobile,
            t2.state,
            t1.department
        FROM
            sys_ding_user AS t1
            LEFT JOIN sys_user AS t2 ON t1.userid = t2.ding_user_id
        <trim prefix="WHERE" prefixOverrides="AND |OR ">
            <if test="loginName !=null and loginName !=''">
                and t2.username LIKE CONCAT('%',#{loginName},'%')
            </if>
            <if test="mobile !=null and mobile !=''">
                and t1.mobile LIKE CONCAT('%',#{mobile},'%')
            </if>
            <if test="state !=null and state !=''">
                and t2.state LIKE CONCAT('%',#{state},'%')
            </if>

        </trim>
    </select>

</mapper>