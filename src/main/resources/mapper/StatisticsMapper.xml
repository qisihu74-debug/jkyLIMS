<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.lims.manage.erp.mapper.StatisticsMapper">


    <resultMap type="com.lims.manage.erp.entity.SampleEntity" id="SampleEntityMap">
        <result property="id" column="id"/>
        <result property="sampleName" column="sample_name"/>
        <collection property="sampleCheckItem" ofType="com.lims.manage.erp.entity.SampleItemInstrumentEntity">
            <id property="checkItemId" column="itemId"></id>
            <result property="checkItemName" column="check_item_name"></result>
            <result property="times" column="times"></result>
            <result property="unitPrice" column="unit_price"></result>
            <result property="state" column="state"></result>
        </collection>
    </resultMap>


    <select id="selectTaskQuery" resultType="com.lims.manage.erp.vo.TaskStatsVo">
        SELECT
        t1.id as taskId,
        t1.task_code taskCode,
        t1.required_completion_time requestDate,
        t1.end_detection_time finishDate,
        t2.report_code reportCode,
        t2.state state,
        t1.entrustment_id
        FROM
        test_task AS t1
        LEFT JOIN test_report_record AS t2 ON t2.entrustment_id = t1.entrustment_id
        WHERE 1=1
        <if test="deptId!=null">
            and t1.dept_id = #{deptId}
        </if>
        <if test="requestDate!=null">
            and t1.required_completion_time <![CDATA[ <= ]]>  #{requestDate}
        </if>
        <if test="finishDate!=null">
            and t1.end_detection_time <![CDATA[ <= ]]>  #{finishDate}
        </if>
        <if test="finishDate!=null">
            and t1.end_detection_time <![CDATA[ <= ]]>  #{finishDate}
        </if>
        <if test="startDate!=null">
            and t1.receive_time <![CDATA[ <= ]]>  #{startDate}
        </if>
        <if test="stopDate!=null">
            and t1.review_time <![CDATA[ <= ]]>  #{stopDate}
        </if>
        ORDER BY t1.task_code DESC
    </select>

    <select id="selectSampleEntityList" resultMap="SampleEntityMap">
    SELECT
        t2.sample_name ,
        t3.id as itemId,
        t3.times,
        t3.unit_price,
        t3.check_item_name,
        t3.state
    FROM
        test_entrusted_sample_details_rel AS t1
        LEFT JOIN test_sample AS t2 ON t1.sample_id = t2.id
        LEFT JOIN test_entrusted_sample_checkitem_rel AS t3 ON t3.sample_id = t2.id
    WHERE
        t1.entrustment_id =#{entrustmentId}
        and t3.task_id = #{taskId}
    </select>

    <select id="selectAllPerson" resultType="com.lims.manage.erp.vo.PersonalStatsVo">
        SELECT
        t2.NAME deptName,
        t2.CODE code,
        t3.NAME name,
        t3.user_id userId
        FROM
        test_technicist AS t1
        LEFT JOIN test_team AS t2 ON t1.team_id = t2.id
        LEFT JOIN sys_user AS t3 ON t3.user_id = t1.user_id
        WHERE 1=1
        <if test="deptIds != null">
            and t2.id in
            <foreach collection="deptIds" item="id" index="index" open="(" close=")" separator=",">
                #{id}
            </foreach>
        </if>
    </select>

    <select id="selectEntrustHistoryListRelease" resultType="com.lims.manage.erp.entity.EntrustHistoryEntity"
            parameterType="com.lims.manage.erp.vo.PersonalStatsVo">
    SELECT
    id,
    entrustment_no,
    entrust_company,
    entrust_people,
    project_name,
    business_acceptor,
    acceptance_date,
    state
    FROM
    test_entrusted_info
    where 1=1
        <if test="startDate!=null">
            and acceptance_date <![CDATA[ >= ]]>  #{startDate}
        </if>
        <if test="stopDate!=null">
            and acceptance_date <![CDATA[ <= ]]>  #{stopDate}
        </if>
    </select>

    <select id="selectTaskTest" resultType="com.lims.manage.erp.entity.TaskTestEntity">
    SELECT
        id,
        inspector inspector,
        reviewer reviewer
    FROM
        test_task
        where 1=1
        <if test="startDate!=null">
            and start_detection_time <![CDATA[ >= ]]>  #{startDate}
        </if>
        <if test="stopDate!=null">
            and end_detection_time <![CDATA[ <= ]]>  #{stopDate}
        </if>
    </select>

    <select id="selectTaskReview" resultType="com.lims.manage.erp.entity.TaskTestEntity">
        SELECT
        id,
        inspector inspector,
        reviewer reviewer
        FROM
        test_task
        where 1=1
        <if test="startDate!=null">
            and review_time <![CDATA[ >= ]]>  #{startDate}
        </if>
        <if test="stopDate!=null">
            and review_time <![CDATA[ <= ]]>  #{stopDate}
        </if>
    </select>

    <select id="selectReportSeal" resultType="com.lims.manage.erp.entity.ReportRecordEntity"
            parameterType="com.lims.manage.erp.vo.PersonalStatsVo">
       SELECT
            id,
            verifyer_id verifyerId,
            issuer_id issuerId,
            sealer sealer
       FROM
            test_report_record
    </select>

    <select id="selectReportVerifyer" resultType="com.lims.manage.erp.entity.ReportRecordEntity"
            parameterType="com.lims.manage.erp.vo.PersonalStatsVo">
       SELECT
            id,
            verifyer_id verifyerId,
            issuer_id issuerId,
            sealer sealer
       FROM
            test_report_record
        where 1=1
        <if test="startDate!=null">
            and verifyer_time <![CDATA[ >= ]]>  #{startDate}
        </if>
        <if test="stopDate!=null">
            and verifyer_time <![CDATA[ <= ]]>  #{stopDate}
        </if>
    </select>

    <select id="selectReportIssuer" resultType="com.lims.manage.erp.entity.ReportRecordEntity"
        parameterType="com.lims.manage.erp.vo.PersonalStatsVo">
        SELECT
        id,
        verifyer_id verifyerId,
        issuer_id issuerId,
        sealer sealer
        FROM
        test_report_record
        where 1=1
        <if test="startDate!=null">
            and issuer_time <![CDATA[ >= ]]>  #{startDate}
        </if>
        <if test="stopDate!=null">
            and issuer_time <![CDATA[ <= ]]>  #{stopDate}
        </if>
    </select>

    <select id="selectAllTeamVo" resultType="com.lims.manage.erp.vo.TestTeamVo">
        SELECT
        id,
        NAME,
        CODE
        FROM
            test_team
        WHERE del_flag = 0
    </select>

    <!--任务列表结果集-->
    <resultMap id="taskResultMap" type="com.lims.manage.erp.vo.TaskStatsVo">
        <result property="taskId" column="task_id"></result>
        <result property="taskCode" column="task_code"></result>
        <result property="orderer" column="orderer"></result>
        <result property="requestDate" column="requestDate"></result>
        <result property="finishDate" column="finishDate"></result>
        <result property="reportCode" column="report_code"></result>
        <result property="reportCode" column="report_code"></result>
        <collection property="sampleDetailList" ofType="com.lims.manage.erp.vo.SampleDetailVo">
            <id property="id" column="sample_id"></id>
            <result property="sampleCode" column="sample_code"></result>
            <result property="sampleName" column="sample_name"></result>
            <result property="productId" column="product_id"></result>
            <result property="specs" column="specs"></result>
            <result property="batchNumber" column="batch_number"></result>
            <result property="generation" column="generation"></result>
            <result property="sampleGroups" column="sample_groups"></result>
            <result property="quantityPerGroup" column="quantity_per_group"></result>
            <result property="sampleOrigin" column="sample_origin"></result>
            <result property="manufacturer" column="manufacturer"></result>
            <result property="receivedDate" column="received_date"></result>
            <result property="inspector" column="inspector"></result>
            <result property="sampleRequirement" column="sample_requirement"></result>
            <result property="outward" column="outward"></result>
            <result property="picture" column="picture"></result>
            <result property="sampleQuantity" column="sample_quantity"></result>
            <result property="aliasName" column="alias_name"></result>
            <result property="sampleRemark" column="sample_remark"></result>
            <result property="sampleType" column="sample_type"></result>
            <collection property="checkItemInfoList" ofType="com.lims.manage.erp.vo.CheckItemInfoVo">
                <id property="checkItemId" column="check_item_id"></id>
                <result property="checkItemName" column="check_item_name"></result>
                <result property="methodId" column="method_id"></result>
                <result property="methodName" column="name"></result>
                <result property="standardId" column="standard_id"></result>
                <result property="standardName" column="standard_name"></result>
                <result property="times" column="times"></result>
                <result property="checkPrice" column="unit_price"></result>
                <result property="itemId" column="itemId"></result>
                <result property="state" column="state"></result>
                <result property="originUrl" column="originUrl"></result>
                <result property="opinion" column="opinion"></result>
                <result property="itemFileName" column="item_file_name"></result>
            </collection>
        </collection>
    </resultMap>

    <select id="getTaskList" resultMap="taskResultMap" parameterType="com.lims.manage.erp.vo.TaskDetailInfoVo">
    SELECT
        t1.id as task_id,
        t1.task_code task_code,
        t1.required_completion_time requestDate,
        t1.end_detection_time finishDate,
        t2.report_code reportCode,
        t2.state state,
        t1.entrustment_id,
		t4.sample_name ,
        t5.id as itemId,
        t5.times,
        t5.unit_price,
        t5.check_item_name,
        t5.state,
		t5.task_id
        FROM
        test_task AS t1
        LEFT JOIN test_report_record AS t2 ON t2.entrustment_id = t1.entrustment_id
				LEFT JOIN test_entrusted_sample_details_rel AS t3 ON t3.entrustment_id = t1.entrustment_id
        LEFT JOIN test_sample AS t4 ON t3.sample_id = t4.id
        LEFT JOIN test_entrusted_sample_checkitem_rel AS t5 ON t5.sample_id = t4.id
        WHERE 1=1
        <if test="deptId!=null">
            and t1.dept_id = #{deptId}
        </if>
        <if test="requestDate!=null">
            and t1.required_completion_time <![CDATA[ <= ]]>  #{requestDate}
        </if>
        <if test="finishDate!=null">
            and t1.end_detection_time <![CDATA[ <= ]]>  #{finishDate}
        </if>
        <if test="finishDate!=null">
            and t1.end_detection_time <![CDATA[ <= ]]>  #{finishDate}
        </if>
        <if test="startDate!=null">
            and t1.receive_time <![CDATA[ <= ]]>  #{startDate}
        </if>
        <if test="stopDate!=null">
            and t1.review_time <![CDATA[ <= ]]>  #{stopDate}
        </if>
        ORDER BY t1.task_code DESC
    </select>
</mapper>