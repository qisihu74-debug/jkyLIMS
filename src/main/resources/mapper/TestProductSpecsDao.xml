<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lims.manage.erp.mapper.TestProductSpecsDao">

    <resultMap type="com.lims.manage.erp.entity.TestProductSpecs" id="TestProductSpecsMap">
        <result property="id" column="id" jdbcType="INTEGER"/>
        <result property="produceId" column="produce_id" jdbcType="INTEGER"/>
        <result property="specs" column="specs" jdbcType="VARCHAR"/>
    </resultMap>

    <!-- 批量插入 -->
    <insert id="insertBatch" keyProperty="id" useGeneratedKeys="true">
        insert into test_product_specs(produce_id, specs)
        values
        <foreach collection="entities" item="entity" separator=",">
        (#{entity.produceId}, #{entity.specs})
        </foreach>
    </insert>
    <!-- 批量插入或按主键更新 -->
    <insert id="insertOrUpdateBatch" keyProperty="id" useGeneratedKeys="true">
        insert into test_product_specs(produce_id, specs)
        values
        <foreach collection="entities" item="entity" separator=",">
            (#{entity.produceId}, #{entity.specs})
        </foreach>
        on duplicate key update
         produce_id = values(produce_id) , specs = values(specs)     </insert>

</mapper>

