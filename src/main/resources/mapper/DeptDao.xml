<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.lims.manage.erp.mapper.DeptDao">

    <resultMap id="BaseResultMap" type="com.lims.manage.erp.vo.DingDeptVo">
        <result column="id" property="id"/>
        <result column="parent_id" property="parentId"/>
        <result column="name" property="name"/>
    </resultMap>

    <resultMap id="NodeTreeResult" type="com.lims.manage.erp.vo.DingDeptVo"
               extends="BaseResultMap">
        <collection property="children" column="id" ofType="com.lims.manage.erp.vo.DingDeptVo"
                    javaType="java.util.ArrayList" select="getNextDept" >
        </collection>
    </resultMap>

    <select id="getAllDept" resultMap="NodeTreeResult">
        SELECT
            id,
            name,
            parent_id parentId
        FROM
            sys_dept
        WHERE id = 1
    </select>

    <select id="getNextDept" resultMap="NodeTreeResult" parameterType="java.lang.Long">
        SELECT
            id,
            name,
            parent_id parentId
        FROM
            sys_dept
        WHERE
            parent_id = #{id}
    </select>

    <select id="getRoleInfoById" parameterType="Long" resultType="com.lims.manage.erp.vo.LabelValueVo">
        SELECT
            id value,
            name label
        FROM
            sys_dept
        WHERE
            id = #{id}
    </select>
    <select id="getAllList"  resultType="com.lims.manage.erp.entity.DingDeptEntity">
        SELECT
        DISTINCT t1.id id,
        t1.parent_id parentId,
        t1.name name,
        t2.name parentName,
        t1.code code,
        t1.duty duty,
        t1.time time,
        t1.update_time updateTime
        FROM
        sys_dept as t1 LEFT JOIN
        sys_dept as t2 ON t1.parent_id = t2.id
        WHERE 1=1
        <if test="search!=null and search!=''">
            and ( t1.name LIKE CONCAT('%',#{search,jdbcType=VARCHAR},'%')
            or t1.code LIKE CONCAT('%',#{search,jdbcType=VARCHAR},'%')
            or t1.duty LIKE CONCAT('%',#{search,jdbcType=VARCHAR},'%')
            )
        </if>
        ORDER BY updateTime desc
    </select>

</mapper>