<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.lims.manage.erp.mapper.TestCustomerDao">


    <insert id="insertTestCustomer" parameterType="com.lims.manage.erp.entity.TestCustomerEntity">
        insert into test_customer
        <trim prefix="(" suffix=")" suffixOverrides=",">
            customer_id,
            <if test="companyId != null and companyId!=0">
                company_id,
            </if>
            <if test="contacts != null and contacts !=''">
                contacts,
            </if>
            <if test="phone != null and phone !=''">
                phone,
            </if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            customer_id,
            <if test="companyId != null and companyId!=0">
                #{companyId},
            </if>
            <if test="contacts != null and contacts !=''">
                #{contacts},
            </if>
            <if test="phone != null and phone !=''">
                #{phone},
            </if>
        </trim>
    </insert>

    <select id="getTestCustomerClientList" resultType="com.lims.manage.erp.vo.TestCustomerVo">
        SELECT
        customer_id Id,
        contacts contacts,
        phone contactWay
        FROM
        `test_customer`
        WHERE company_id = #{companyId}
        <if test="contacts!=null and contacts!=''">
            and contacts = #{contacts}
        </if>
    </select>

    <select id="selectCustomerList" resultType="com.lims.manage.erp.entity.TestCustomerEntity">
        SELECT
        customer_id,
        contacts,
        phone,
        company_id
        FROM
        `test_customer`
        <trim prefix="WHERE" prefixOverrides="AND |OR ">
            and company_id in
            <foreach item="item" index="index" collection="companyIds"
                     open="(" separator="," close=")">
                #{item}
            </foreach>
        </trim>
    </select>

    <select id="selectEntrustList" resultType="com.lims.manage.erp.vo.EntrustAddVo">
        SELECT
        id,
        IFNULL(CONCAT(entrust_category_type,entrustment_no),entrustment_no) as entrustmentNostr,
        entrust_company,
        entrust_people,
        entrust_phone,
        discount,
        actual_price,
        system_price
        FROM
        test_entrusted_info
        <trim prefix="WHERE" prefixOverrides="AND |OR ">
            <if test="companyId!=null and companyId!=''">
                and entrust_company_id =#{companyId}
            </if>
            <if test="entrustmentNo!=null and entrustmentNo!=''">
                and IFNULL(CONCAT(entrust_category_type,entrustment_no),entrustment_no) like
                concat('%',#{entrustmentNo},'%')
            </if>
        </trim>
    </select>

    <select id="selectEntrusTotalMoney" resultType="java.lang.String">
        SELECT
        ROUND(sum(system_price),2)
        FROM
        test_entrusted_info
        <trim prefix="WHERE" prefixOverrides="AND |OR ">
            <if test="companyId!=null and companyId!=''">
                and entrust_company_id =#{companyId}
            </if>
            <if test="entrustmentNo!=null and entrustmentNo!=''">
                and IFNULL(CONCAT(entrust_category_type,entrustment_no),entrustment_no) like
                concat('%',#{entrustmentNo},'%')
            </if>
        </trim>
    </select>


</mapper>