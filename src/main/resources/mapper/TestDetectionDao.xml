<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.lims.manage.erp.mapper.TestDetectionDao">

    <select id="selectTheInstrument" resultType="com.lims.manage.erp.entity.TestInstrumentEntity">
        SELECT
        t1.id AS id,
        t1.type_id AS typeId,
        t1.name AS name,
        t1.code AS code,
        t1.model AS model
        FROM test_instrument as t1
        LEFT JOIN test_product_item_instrument_type_rel as t2 ON t1.type_id = t2.intrusment_type_id
        WHERE t2.check_item_id = #{checkItemId}
    </select>
    <update id="updateSampleItemInstrumentEntity" parameterType="com.lims.manage.erp.entity.SampleItemInstrumentEntity">
        UPDATE test_entrusted_sample_checkitem_rel
        <trim prefix="SET" suffixOverrides=",">
        <if test="startTime!=null">start_time=#{startTime},</if>
        </trim>
         WHERE id = #{itemId}
    </update>
    <insert id="addItemInstrumentMiddleRel" parameterType="com.lims.manage.erp.entity.TestChItemInstrumentMiddleEntity"
            useGeneratedKeys="true" keyProperty="id">
        INSERT into test_product_item_instrument_middle_rel (id_item,intrusment_id) VALUES(#{sidItem},#{intrusmentId})
    </insert>
    <select id="getTestEntrustedSampleCheckitemRelDetail" resultType="com.lims.manage.erp.entity.SampleItemInstrumentEntity" >
        SELECT
        id AS itemId,
        start_time,
        end_time,
        result,
        test_people
        FROM
        test_entrusted_sample_checkitem_rel
        WHERE  id = #{id}
    </select>

</mapper>