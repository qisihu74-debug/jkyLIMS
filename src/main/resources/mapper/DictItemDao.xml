<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.lims.manage.erp.mapper.DictItemDao">

    <select id="getDictItemTree" parameterType="String" resultType="com.lims.manage.erp.vo.DictItemTreeVo">
        SELECT item_id, dict_id, parent_item_id, item_text,item_sort
        FROM t_dict_item WHERE parent_item_id = #{parentId}
        ORDER BY item_sort
    </select>

</mapper>