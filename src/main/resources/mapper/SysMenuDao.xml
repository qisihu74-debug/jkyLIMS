<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.lims.manage.erp.mapper.SysMenuDao">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.lims.manage.erp.entity.SysMenuEntity" id="sysMenuMap">
        <result property="menuId" column="menu_id"/>
        <result property="parentId" column="parent_id"/>
        <result property="name" column="name"/>
        <result property="url" column="url"/>
        <result property="perms" column="perms"/>
        <result property="type" column="type"/>
        <result property="icon" column="icon"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <!-- 查询用户权限集合 -->
    <select id="selectSysMenuByRoleId" parameterType="long" resultType="com.lims.manage.erp.entity.SysMenuEntity">
      SELECT sm.* FROM sys_menu sm
      LEFT JOIN sys_role_menu se ON sm.menu_id = se.menu_id
      WHERE se.role_id = #{roleId}
    </select>

    <select id="selectSysMenuEntityListByUserId" resultType="com.lims.manage.erp.entity.SysMenuEntity">
        SELECT
            *
        FROM
            sys_menu
        WHERE
            menu_id IN ( SELECT menu_id FROM sys_role_menu WHERE role_id IN ( SELECT role_id FROM sys_user_role WHERE user_id = #{userId} ) )
    </select>


</mapper>