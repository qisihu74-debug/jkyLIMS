<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.lims.manage.erp.mapper.SysUserRoleDao">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.lims.manage.erp.entity.SysUserRoleEntity" id="sysUserRoleMap">
        <result property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="roleId" column="role_id"/>
    </resultMap>

    <delete id="removeOldRole">
        DELETE FROM sys_user_role where user_id = #{userId}
    </delete>

    <insert id="insertNewRole" parameterType="com.lims.manage.erp.entity.SysUserRoleEntity">
        insert into sys_user_role(user_id, role_id) values(#{userId}, #{roleId})
    </insert>
</mapper>