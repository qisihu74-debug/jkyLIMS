<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.lims.manage.erp.mapper.SampleFileTableDao">

    <insert id="insertSampleFileTableEntity" parameterType="com.lims.manage.erp.entity.SampleFileTableEntity">
        insert into test_sample_file_rel(sample_id,file_url,file_url_str,create_time) values (#{sampleId},#{fileUrl},#{fileUrlStr},#{carateTime})
    </insert>

    <select id="getSampleFileTableEntityList" resultType="com.lims.manage.erp.entity.SampleFileTableEntity">
				SELECT
				id,
				file_url,
				file_url_str
				FROM
				test_sample_file_rel
				WHERE sample_id = #{sampleId}
    </select>

	<select id="getSampleFileTableEntityId" resultType="com.lims.manage.erp.entity.SampleFileTableEntity">
		SELECT
			id,
			file_url,
			file_url_str,
			create_time,
			update_time
			FROM
			test_sample_file_rel
			WHERE id = #{id}
	</select>

	<delete id="deleteSampleFileTableEntity">
		delete from test_sample_file_rel where id = #{id}
	</delete>



</mapper>